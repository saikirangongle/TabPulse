{
  "manifest_version": 3,
  "name": "TabPulse",
  "description": "Advanced tab-level bandwidth analytics with real-time monitoring, anomaly detection, predictive insights, and visual dashboards.",
  "version": "1.5.0",
  "permissions": [
    "webRequest","tabs","storage","activeTab","alarms","notifications","scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "TabPulse",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content/content.js"],
    "run_at": "document_idle"
  }],
  "web_accessible_resources": [{
    "resources": [
      "dashboard/dashboard.html",
      "dashboard/minChart.js",
      "styles/dashboard.css",
      "styles/popup.css",
      "icons/icon48.png"
    ],
    "matches": ["<all_urls>"]
  }],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_chrome_version": "110"
}
